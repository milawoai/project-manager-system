{
  "name": "electron-app",
  "version": "1.0.0",
  "description": "An Electron application with Vue and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "yarn typecheck:node && yarn typecheck:web",
    "start": "yarn electron-vite preview",
    "dev": "yarn electron-vite dev",
    "build": "yarn typecheck && yarn electron-vite build",
    "build:no-lint": "yarn electron-vite build",
    "clean": "rm -rf out dist build",
    "postinstall": "echo 'Skipping electron-builder install-app-deps in monorepo setup'",
    "build:unpack": "yarn build:no-lint && yarn node scripts/copy-services.js && yarn electron-builder --dir",
    "build:win": "yarn build:no-lint && yarn node scripts/copy-services.js && yarn electron-builder --win",
    "build:mac": "yarn build:no-lint && yarn node scripts/copy-services.js && yarn electron-builder --mac",
    "build:linux": "yarn build:no-lint && yarn node scripts/copy-services.js && yarn electron-builder --linux",
    "copy-services": "yarn node scripts/copy-services.js",
    "prebuild": "echo '准备构建...'",
    "postbuild": "echo '构建完成!'",
    "build:electron": "turbo run build:electron --filter=electron-app && yarn copy-services && yarn electron-builder"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@logicflow/core": "^2.0.12",
    "@logicflow/extension": "^2.0.16",
    "@primeuix/themes": "^1.0.0",
    "@tailwindcss/vite": "^4.0.17",
    "@tdesign-vue-next/chat": "^0.3.0",
    "axios": "^1.8.4",
    "better-sqlite3": "^12.6.2",
    "editorconfig": "^3.0.0",
    "electron-store": "8.2.0",
    "express": "^5.2.1",
    "kill-port": "^2.0.1",
    "primeicons": "^7.0.0",
    "primevue": "^4.3.311.0.2",
    "socket.io-client": "^4.8.3",
    "tailwindcss-primeui": "^0.6.1",
    "toml": "^3.0.0",
    "uuid": "^13.0.0",
    "volta": "^0.0.0",
    "vue-i18n": "^11.1.11",
    "vue-router": "4",
    "ws": "^8.18.3",
    "yaml": "^2.8.0",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@primevue/auto-import-resolver": "^4.3.3",
    "@rushstack/eslint-patch": "^1.11.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron-store": "^3.2.2",
    "@types/node": "^22.13.4",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "eslint": "^9.20.1",
    "eslint-plugin-vue": "^9.32.0",
    "less": "^4.2.2",
    "less-loader": "^12.2.0",
    "postcss": "^8.5.3",
    "prettier": "^3.6.2",
    "sass": "1.62.1",
    "tailwindcss": "3.4.16",
    "typescript": "^5.7.3",
    "unplugin-auto-import": "^0.17.6",
    "unplugin-vue-components": "^28.4.1",
    "vite": "^6.1.0",
    "vite-plugin-commonjs": "^0.10.4",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.2"
  },
  "volta": {
    "node": "22.17.0"
  }
}
